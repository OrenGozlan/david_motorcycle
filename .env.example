# Sanity — catalog CMS
# Public (used at build time for read queries; safe to expose)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Read token — only needed if the dataset is private. Set as a GitHub Actions
# secret for the deploy build; keep out of the repo.
SANITY_API_READ_TOKEN=

# Write token — LOCAL ONLY, used by `pnpm seed`. Never commit / never in CI.
SANITY_API_WRITE_TOKEN=

# Site
NEXT_PUBLIC_SITE_URL=https://david-motorcycle.example
# Set only when serving from a GitHub Pages project sub-path (/<repo>). Leave
# empty for a user/org page or a custom domain served at the root.
NEXT_PUBLIC_BASE_PATH=

# Optional: used by scripts/translate-ui.ts to auto-fill en/ru from he
ANTHROPIC_API_KEY=
